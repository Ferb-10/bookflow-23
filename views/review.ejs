<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wdth,wght@75,100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Alfa+Slab+One&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"/>
    <link rel="stylesheet" href="/style/style.css">
    <title>BookFlow review</title>
</head>
<body>
    <div class="app">
        <%- include('partials/sidebar.ejs') %>
        <main class="main">
            <div class="content">
                <h2>Finished Reading</h2>
                <p>Track your reading journey, from want-to-read to finished books.</p>
            </div>

            <!-- view section -->
            <% if(viewBook) { %>
            <div class="book-detail">
                <a href="/review"><span class="material-symbols-outlined"> close </span></a>
                <div class="book-flex-container">
                    <div class="book-content">
                        <h2><%= viewBook.title %></h2>
                        <p><%= viewBook.author %></p>
                        <p>Date added：<%= viewBook.review_date.toLocaleDateString('sv-SE') %></p>
                        <% const rating = Number(viewBook.review) || 0 %>
                        <div class="review-stars">
                            <% for(let i = 1; i <= 5; i++) { %>
                                <span class="star <%= i <= rating ? 'active' : '' %>">★</span>
                            <% } %>
                        </div>
                    </div>
                    <img src="<%= viewBook.cover_url || '/img/no-cover.png' %>" alt="">
                </div>
                <div class="note">
                    <h2>Note:</h2>
                    <p><%= viewBook.comment || "No comment" %></p>
                </div>
            </div>
            <% } %>

            <!-- update section -->
            <% if (updateBook) { %>
            <form action="/review/<%= updateBook.id %>/update" method="POST" class="book-detail">
                <a href="/review"><span class="material-symbols-outlined">close</span></a>
                <button type="submit" class="btn primary"><span class="material-symbols-outlined">add_2</span></button>
                <div class="book-flex-container">
                    <div class="book-content">
                        <h2><%= updateBook.title %></h2>
                        <p><%= updateBook.author %></p>
                        <p>Date added：<%= updateBook.review_date.toLocaleDateString('sv-SE') %></p>
                        <div class="stars">
                            <span>
                                <input id="r5" type="radio" name="review" value="5" <%= updateBook.review == 5 ? "checked" : "" %>>
                                <label for="r5">★</label>

                                <input id="r4" type="radio" name="review" value="4" <%= updateBook.review == 4 ? "checked" : "" %>>
                                <label for="r4">★</label>

                                <input id="r3" type="radio" name="review" value="3" <%= updateBook.review == 3 ? "checked" : "" %>>
                                <label for="r3">★</label>

                                <input id="r2" type="radio" name="review" value="2" <%= updateBook.review == 2 ? "checked" : "" %>>
                                <label for="r2">★</label>

                                <input id="r1" type="radio" name="review" value="1" <%= updateBook.review == 1 ? "checked" : "" %>>
                                <label for="r1">★</label>
                            </span>
                        </div>
                    </div>
                    <div class="cover">
                        <img src="<%= updateBook.cover_url %>">
                    </div>
                </div>
                <div class="note">
                    <h2>Note:</h2>
                    <textarea name="comment"><%= updateBook.comment %></textarea>
                </div>

            </form>
            <% } %>
            <!-- finish一覧 -->
            <div class="finish-container">
                <div class="grid-container">
                    <% finishedBooks.forEach(book => { %>
                    <div class="grid-content">
                        <div class="flex-column">
                            <div class="cover">
                                <img src="<%= book.cover_url || '/img/no-cover.png' %>" alt="">
                            </div> 
                            <h2><%= book.title %></h2>
                            <p><%= book.author %></p>
                            <% const rating = Number(book.review) || 0 %>
                            <div class="review-stars small">
                                <% for(let i = 1; i <= 5; i++) { %>
                                <span class="star <%= i <= rating ? 'active' : '' %>">★</span>
                                <% } %>
                            </div>
                        </div>
                        <div class="btns">
                            <button class="btn"><span class="material-symbols-outlined"> more_horiz </span></button>
                            <div class="menu_sub hidden">
                                <a href="/review?view=<%= book.id %>">View</a>
                                <a href="/review?update=<%= book.id %>">Update</a>
                                <form action="/books/<%= book.id %>/delete" method="POST">
                                    <button type="submit">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% }); %>   
                </div>
            </div>
        </main>
    </div>
</body>
<script>
    document.addEventListener("click", (e) => {
    const btn = e.target.closest(".btn");
    const allMenus = document.querySelectorAll(".menu_sub");

  
    allMenus.forEach(menu => menu.classList.add("hidden"));

  
    if (btn) {
        const menu = btn.nextElementSibling;
        menu.classList.toggle("hidden");
        }
    });



    const textarea = document.getElementById("autoTextarea");

    textarea.addEventListener("input", () => {
    textarea.style.height = "auto";                 // 一旦リセット
    textarea.style.height = textarea.scrollHeight + "px";
    });
</script>
</html>