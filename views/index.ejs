<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wdth,wght@75,100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Alfa+Slab+One&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"/>
    <link rel="stylesheet" href="/style/style.css">
    <title>BookFlow</title>
</head>
<body>
    <div class="app">
        <%- include('partials/sidebar.ejs') %>
        <main class="main">
            <div class="search-box">
                <div class="content">
                    <h2>Welcome to BackFlow</h2>
                    <p>Track your reading journey, from want-to-read to finished books.</p>
                </div>
                <div class="form">
                    <form action="/search" method="POST">
                        <input type="text" placeholder="Search for books ..." name="bookName">
                        <button type="submit">Search</button> 
                    </form>
                </div>
            </div>
        <!-- Search -->
        <% if (error) { %>
            <p class="error"><%= error %></p> 
        <% } else if (locals.firstFourResults && firstFourResults.length > 0) { %>    
            <div class="search-result-box">
                <div class="grid-container">
                <% firstFourResults.forEach(result => { %>   
                    <% const status = savedMap.get(result.key); %> 
                    <div class="grid-content">
                        <div class="flex-column">
                            <div class="cover">
                                <% const coverId = result.cover_edition_key; %>
                                <img src="<%= coverId ? `https://covers.openlibrary.org/b/olid/${coverId}.jpg` : '/img/no-cover.png' %>" onerror="this.onerror=null; this.src='/img/no-cover.png';">
                            </div>
                            <h2><%= result.title %></h2>
                            <p><%= result.author_name ? result.author_name.join(', ') : 'Unknown' %></p>
                        </div>
                        <div class="btns">
                            <% if (!status) { %>
                            <form action="/books" method="POST">
                                <input type="hidden" name="title" value="<%= result.title %>">
                                <input type="hidden" name="author" value="<%= result.author_name %>">
                                <input type="hidden" name="work_id" value="<%= result.key %>">
                                <input type="hidden" name="status" value="want">
                                <input type="hidden" name="cover_edition_id" value="<%= result.cover_edition_key %>">
                                <button type="submit" class="btn">
                                    <span class="material-symbols-outlined"> add </span>
                                </button>
                            </form>
                            <% } else if (status === 'want') { %>
                                <button><span class="material-symbols-outlined"> check </span></button>
                            <% } else if (status === 'finished') { %>
                                <button><span class="material-symbols-outlined"> star </span></button>
                            <% }; %>
                        </div>
                    </div>
                <% }); %>
                </div>
            </div>
        <% }; %>
            <!-- want一覧 -->
            <div class="wanted-reading">
                <div class="flex">
                    <h2>Want to Read <span>(<%= locals.wantCount %>)</span></h2>
                    <a href="/want">View All ></a>
                </div>
                <div class="container">
                <% wantBooks.forEach(book => { %>
                    <div class="card">
                        <div class="card-content">
                            <div class="cover">
                                <img src="<%= book.cover_url || '/img/no-cover.png' %>" alt="book_cover">
                            </div>
                            <div class="contents">
                                <h2><%= book.title %></h2>
                                <p><%= book.author %></p>
                            </div>
                        </div>
                        <div class="book-item">
                            <button class="menu-btn"><span class="material-symbols-outlined"> more_horiz </span></button>
                            <div class="menu hidden">
                                <a href="/want?review=<%= book.id %>">Review</a>
                                <form action="/books/<%= book.id %>/delete" method="POST">
                                    <input type="hidden" name="bookId" value="<%= book.id %>">
                                    <button type="submit">Delete</button>
                                </form>  
                            </div>
                        </div>
                    </div>
                <% });  %>
                </div>
            </div>
            <!-- finish一覧 -->
            <div class="finished-reading">
                <div class="flex">
                    <h2>Finished-reading <span>(<%= locals.finishedCount %>)</span></h2>
                    <a href="/review">View All ></a>
                </div>
                <div class="container">
                    <% finishedBooks.forEach(book => { %>
                    <div class="card">
                        <div class="card-content">
                            <div class="cover">
                                <img src="<%= book.cover_url || '/img/no-cover.png' %>" alt="book_cover">
                            </div>
                            <div class="contents">
                                <h2><%= book.title %></h2>
                                <p><%= book.author %></p>
                                <% const rating = Number(book.review) || 0 %>
                                <div class="review-stars small">
                                    <% for(let i = 1; i <= 5; i++) { %>
                                        <span class="star <%= i <= rating ? 'active' : '' %>">★</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <div class="book-item">
                            <button class="menu-btn"><span class="material-symbols-outlined"> more_horiz </span></button>
                            <div class="menu hidden">
                                <a href="/review?view=<%= book.id %>">View</a>
                                <a href="/review?update=<%= book.id %>">Update</a>
                                <form action="/books/<%= book.id %>/delete" method="POST">
                                    <button type="submit">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </main>
    </div>
</body>
<script>
    document.addEventListener("click", (e) => {
    const btn = e.target.closest(".menu-btn");
    const allMenus = document.querySelectorAll(".menu");
    allMenus.forEach(menu => menu.classList.add("hidden"));
    if (btn) {
        const menu = btn.nextElementSibling;
        menu.classList.toggle("hidden");
        }
    });
</script>
</html>