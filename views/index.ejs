<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wdth,wght@75,100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Alfa+Slab+One&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"/>
    <link rel="stylesheet" href="/style/style.css">
    <!-- <link rel="stylesheet" href="../public/style/style.css"> -->
    <title>BookFlow</title>
</head>
<body>
    <div class="app">
        <!-- :::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::: -->
        <aside class="sidebar">
            <div class="logo">
                <h1><img src="/img/icon.png" alt=""><span>Book</span>Flow</h1>
            </div>
            <div class="nav-items">
                <div class="item">
                    <a href="/"><span class="material-symbols-outlined"> search </span>Search</a>
                </div>
                <div class="item">
                    <a href="/want"><span class="material-symbols-outlined"> bookmark </span>Want to Read</a>
                </div>
                <div class="item">
                    <a href="/review"><span class="material-symbols-outlined"> bookmark_star </span>Finished Reading</a>
                </div>
            </div>
        </aside>
        <!-- :::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::: -->
        <main class="main">
            <div class="search-box">
                <div class="content">
                    <h2>Welcome to BackFlow</h2>
                    <p>Track your reading journey, from want-to-read to finished books.</p>
                </div>
                <div class="form">
                    <form action="/search" method="POST">
                        <input type="text" placeholder="Search for books ..." name="bookName">
                        <button type="submit">Search</button> 
                    </form>
                </div>
            </div>
<!-- ********************************************************************************************************************** -->
 <!-- searchして結果を出力するときだけ表示 -->  
        <% if (locals.firstFourResults) { %>    
            <div class="search-result-box">
                <div class="grid-container">
                <% firstFourResults.forEach(result => { %>   
                    <% const status = savedMap.get(result.cover_edition_key); %> 
                    <div class="grid-content">
                        <div class="flex-column">
                            <div class="cover">
                                <img src="https://covers.openlibrary.org/b/olid/<%= result.cover_edition_key %>.jpg" onerror="this.onerror=null; this.src='img/no-cover.png';" alt="">
                            </div>
                            <h2><%= result.title %></h2>
                            <p><%= result.author_name %></p>
                        </div>
                        <div class="btns">
                            <% if (!status) { %>
                            <form action="/books" method="POST">
                                <input type="hidden" name="title" value="<%= result.title %>">
                                <input type="hidden" name="author" value="<%= result.author_name %>">
                                <input type="hidden" name="cover_url" value="https://covers.openlibrary.org/b/olid/<%= result.cover_edition_key %>.jpg">
                                <input type="hidden" name="status" value="want">
                                <input type="hidden" name="openlibrary_id" value="<%= result.cover_edition_key %>">
                                <button type="submit" class="btn">
                                    <span class="material-symbols-outlined"> add </span>
                                </button>
                            </form>
                            <% } else if (status === 'want') { %>
                                <button><span class="material-symbols-outlined"> check </span></button>
                            <% } else if (status === 'finished') { %>
                                <button><span class="material-symbols-outlined"> star </span></button>
                            <% }; %>
                        </div>
                    </div>
                <% }); %>
                </div>
            </div>
        <% }; %>
<!-- ********************************************************************************************************************** -->
            <!-- :::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::: -->
            <div class="wanted-reading">
                <div class="flex">
                    <h2>Want to Read <span>(3)</span></h2>
                    <a href="/want">View All ></a>
                </div>
                <div class="container">
                    <!-- 最初の3つを表示する仕組み -->
                    <div class="card">
                        <div class="card-content">
                            <img src="/img/cover.png" alt="">
                            <div class="contents">
                                <h2>Atomic Habit</h2>
                                <p>James Clear</p>
                                <p>ISBN: 978013345898</p>
                            </div>
                        </div>
                        <div class="book-item">
                            <button class="menu-btn"><span class="material-symbols-outlined"> more_horiz </span></button>
                            <div class="menu hidden">
                                <button>Review</button>
                                <button>Delete</button>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
            <!-- :::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::: -->

            <div class="finished-reading">
                <div class="flex">
                    <h2>Finished-reading <span>(4)</span></h2>
                    <a href="/reveiw">View All ></a>
                </div>
                <div class="container">
                    <!-- 最初の3つを表示する仕組み -->
                    <div class="card">
                        <div class="card-content">
                            <img src="/img/cover.png" alt="">
                            <div class="contents">
                                <h2>Atomic Habit</h2>
                                <p>James Clear</p>
                                <div class="review-stars small" data-rating="4">
                                    <span class="star active">★</span>
                                    <span class="star active">★</span>
                                    <span class="star active">★</span>
                                    <span class="star active">★</span>
                                    <span class="star">★</span>
                                </div>
                            </div>
                        </div>
                        <div class="book-item">
                            <button class="menu-btn"><span class="material-symbols-outlined"> more_horiz </span></button>
                            <div class="menu hidden">
                                <button>Update</button>
                                <button>Delete</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- :::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::: -->
        </main>
    </div>
</body>
<script>
    document.addEventListener("click", (e) => {
    const btn = e.target.closest(".menu-btn");
    const allMenus = document.querySelectorAll(".menu");

  
    allMenus.forEach(menu => menu.classList.add("hidden"));

  
    if (btn) {
        const menu = btn.nextElementSibling;
        menu.classList.toggle("hidden");
        }
    });
</script>
</html>